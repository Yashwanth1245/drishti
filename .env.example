# DRISHTI — Zoho Catalyst QuickML credentials.  DO NOT COMMIT (gitignored).
#
# Paste your values after the = signs (no quotes needed).
# The first four are required; the rest are prefilled from the datathon docs.
# When the access token expires, the app auto-refreshes it using the refresh
# token + client credentials (new token cached in .zoho_token_cache.json).

ZOHO_ACCESS_TOKEN=PASTE_ACCESS_TOKEN_HERE
ZOHO_REFRESH_TOKEN=PASTE_REFRESH_TOKEN_HERE
ZOHO_CLIENT_ID=PASTE_CLIENT_ID_HERE
ZOHO_CLIENT_SECRET=PASTE_CLIENT_SECRET_HERE

# One of the Authorized Redirect URIs registered with your client:
ZOHO_REDIRECT_URI=https://www.zoho.com/catalyst

# India data center (matches api.catalyst.zoho.in):
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in

CATALYST_ORG=60075642221
QUICKML_PROJECT_ID=50351000000013025
QUICKML_BASE=https://api.catalyst.zoho.in/quickml/v1
GLM_MODEL=crm-di-glm47b_30b_it
VLM_MODEL=VL-Qwen3.6-35B-A3B

# Phase 5 — signs the RBAC login tokens. Any long random string; REQUIRED in
# production (a warning-logged dev fallback is used if unset locally):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
DRISHTI_SECRET=PASTE_RANDOM_SECRET_HERE
